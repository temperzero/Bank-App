{
  "info": {
    "_postman_id": "234c75a6-56c7-4ed7-84be-c854ad3cfd2f",
    "name": "Bank API Register Login Transaction",
    "description": "End-to-end test flow: register sender and recipient, verify them for test automation, login sender, send money, and fetch sender history.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "password",
      "value": "0000"
    },
    {
      "key": "otp",
      "value": "123456"
    },
    {
      "key": "amount",
      "value": "25.75"
    },
    {
      "key": "senderEmail",
      "value": ""
    },
    {
      "key": "recipientEmail",
      "value": ""
    },
    {
      "key": "senderUserId",
      "value": ""
    },
    {
      "key": "recipientUserId",
      "value": ""
    },
    {
      "key": "transactionId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Register Sender",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now().toString().slice(-8);",
              "pm.collectionVariables.set('senderEmail', `sender-${suffix}@example.com`);",
              "pm.collectionVariables.set('recipientEmail', `recipient-${suffix}@example.com`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('sender registration succeeds', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.expect(json).to.have.property('userId');",
              "pm.collectionVariables.set('senderUserId', json.userId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{senderEmail}}\",\n  \"password\": \"{{password}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/signup",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "signup"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. Verify Sender For Test",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('sender verification succeeds', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{senderUserId}}\",\n  \"otp\": \"{{otp}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/verify-otp",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "verify-otp"
          ]
        }
      },
      "response": []
    },
    {
      "name": "3. Login Sender",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('sender login succeeds', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{senderEmail}}\",\n  \"password\": \"{{password}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "4. Register Recipient",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('recipient registration succeeds', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.expect(json).to.have.property('userId');",
              "pm.collectionVariables.set('recipientUserId', json.userId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{recipientEmail}}\",\n  \"password\": \"{{password}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/signup",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "signup"
          ]
        }
      },
      "response": []
    },
    {
      "name": "5. Verify Recipient For Test",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('recipient verification succeeds', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{recipientUserId}}\",\n  \"otp\": \"{{otp}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/verify-otp",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "verify-otp"
          ]
        }
      },
      "response": []
    },
    {
      "name": "6. Send Transaction",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('transaction succeeds', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.expect(json.type).to.eql('sent');",
              "pm.expect(json.otherParty).to.eql(pm.collectionVariables.get('recipientEmail'));",
              "pm.collectionVariables.set('transactionId', json._id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"recipientEmail\": \"{{recipientEmail}}\",\n  \"amount\": {{amount}}\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/transaction/send",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "transaction",
            "send"
          ]
        }
      },
      "response": []
    },
    {
      "name": "7. Get Sender History",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('history succeeds', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.expect(json.transactions).to.be.an('array');",
              "pm.expect(json.transactions.length).to.be.above(0);",
              "pm.expect(json.transactions[0].type).to.eql('sent');",
              "pm.expect(json.transactions[0].otherParty).to.eql(pm.collectionVariables.get('recipientEmail'));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/transaction/history?page=1&limit=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "transaction",
            "history"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      },
      "response": []
    }
  ]
}
