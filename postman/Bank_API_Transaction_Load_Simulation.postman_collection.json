{
  "info": {
    "_postman_id": "c4d00f99-6b49-4ef4-bd2f-73578294b111",
    "name": "Bank API Transaction Load Simulation",
    "description": "Creates verified test users and simulates many transactions into one account so /transaction/history can be checked for pagination. Run the single request with the Postman Collection Runner while the API is running locally.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "simulationUserCount",
      "value": "8"
    },
    {
      "key": "simulationTransactionCount",
      "value": "75"
    },
    {
      "key": "historyPageLimit",
      "value": "10"
    },
    {
      "key": "simulationPassword",
      "value": "0000"
    },
    {
      "key": "simulationOtp",
      "value": "123456"
    },
    {
      "key": "simulationRunId",
      "value": ""
    },
    {
      "key": "simulationUsers",
      "value": "[]"
    },
    {
      "key": "simulationSummary",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Run transaction pagination load simulation",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('simulationRunId', Date.now().toString().slice(-8));",
              "pm.collectionVariables.set('simulationUsers', '[]');",
              "pm.collectionVariables.set('simulationSummary', 'Simulation running...');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const baseUrl = pm.collectionVariables.get('baseUrl');",
              "const userCount = Number(pm.collectionVariables.get('simulationUserCount') || 8);",
              "const transactionCount = Number(pm.collectionVariables.get('simulationTransactionCount') || 75);",
              "const historyPageLimit = Number(pm.collectionVariables.get('historyPageLimit') || 10);",
              "const password = pm.collectionVariables.get('simulationPassword') || '0000';",
              "const otp = pm.collectionVariables.get('simulationOtp') || '123456';",
              "const runId = pm.collectionVariables.get('simulationRunId') || Date.now().toString().slice(-8);",
              "",
              "function parseJson(response) {",
              "    try {",
              "        return response.json();",
              "    } catch (error) {",
              "        return response.text();",
              "    }",
              "}",
              "",
              "function cookieFrom(response) {",
              "    const setCookie = response.headers.get('Set-Cookie');",
              "",
              "    if (!setCookie) {",
              "        return '';",
              "    }",
              "",
              "    return setCookie.split(';')[0];",
              "}",
              "",
              "function request(method, path, body, cookie) {",
              "    return new Promise((resolve, reject) => {",
              "        const headers = [{ key: 'Content-Type', value: 'application/json' }];",
              "",
              "        if (cookie) {",
              "            headers.push({ key: 'Cookie', value: cookie });",
              "        }",
              "",
              "        pm.sendRequest({",
              "            url: `${baseUrl}${path}`,",
              "            method,",
              "            header: headers,",
              "            body: body === undefined ? undefined : {",
              "                mode: 'raw',",
              "                raw: JSON.stringify(body)",
              "            }",
              "        }, (error, response) => {",
              "            if (error) {",
              "                reject(error);",
              "                return;",
              "            }",
              "",
              "            const data = parseJson(response);",
              "",
              "            if (response.code >= 400) {",
              "                reject(new Error(`${method} ${path} failed: ${response.code} ${JSON.stringify(data)}`));",
              "                return;",
              "            }",
              "",
              "            resolve({ data, response, cookie: cookieFrom(response) });",
              "        });",
              "    });",
              "}",
              "",
              "function testUser(index) {",
              "    return {",
              "        email: `load-${runId}-${index}@example.com`,",
              "        password",
              "    };",
              "}",
              "",
              "function amountFor(index) {",
              "    return Number((1 + (index % 9) + ((index % 4) * 0.25)).toFixed(2));",
              "}",
              "",
              "async function login(user) {",
              "    const loginResult = await request('POST', '/auth/login', {",
              "        email: user.email,",
              "        password: user.password",
              "    });",
              "",
              "    if (!loginResult.cookie) {",
              "        throw new Error(`Login did not return an auth cookie for ${user.email}`);",
              "    }",
              "",
              "    return loginResult.cookie;",
              "}",
              "",
              "(async function runSimulation() {",
              "    if (userCount < 2) {",
              "        throw new Error('simulationUserCount must be at least 2');",
              "    }",
              "",
              "    if (transactionCount <= historyPageLimit) {",
              "        throw new Error('simulationTransactionCount must be greater than historyPageLimit to test pagination');",
              "    }",
              "",
              "    const users = [];",
              "",
              "    for (let index = 0; index < userCount; index += 1) {",
              "        const user = testUser(index);",
              "        const signup = await request('POST', '/auth/signup', user);",
              "",
              "        await request('POST', '/auth/verify-otp', {",
              "            userId: signup.data.userId,",
              "            otp",
              "        });",
              "",
              "        user.userId = signup.data.userId;",
              "        users.push(user);",
              "    }",
              "",
              "    const targetUser = users[0];",
              "    const senderUsers = users.slice(1);",
              "    const sentTransactions = [];",
              "",
              "    for (let index = 0; index < transactionCount; index += 1) {",
              "        const sender = senderUsers[index % senderUsers.length];",
              "        const amount = amountFor(index);",
              "        const senderCookie = await login(sender);",
              "",
              "        const transaction = await request('POST', '/transaction/send', {",
              "            recipientEmail: targetUser.email,",
              "            amount",
              "        }, senderCookie);",
              "",
              "        sentTransactions.push(transaction.data);",
              "    }",
              "",
              "    const targetCookie = await login(targetUser);",
              "    const page1 = await request('GET', `/transaction/history?page=1&limit=${historyPageLimit}`, undefined, targetCookie);",
              "    const page2 = await request('GET', `/transaction/history?page=2&limit=${historyPageLimit}`, undefined, targetCookie);",
              "    const lastPageNumber = page1.data.pagination.totalPages;",
              "    const lastPage = await request('GET', `/transaction/history?page=${lastPageNumber}&limit=${historyPageLimit}`, undefined, targetCookie);",
              "",
              "    const summary = {",
              "        runId,",
              "        usersCreated: users.length,",
              "        targetUserEmail: targetUser.email,",
              "        transactionsSentToTarget: sentTransactions.length,",
              "        historyPageLimit,",
              "        page1Transactions: page1.data.transactions.length,",
              "        page2Transactions: page2.data.transactions.length,",
              "        totalHistoryRecordsForTarget: page1.data.pagination.total,",
              "        totalPagesForTarget: page1.data.pagination.totalPages,",
              "        lastPageTransactions: lastPage.data.transactions.length",
              "    };",
              "",
              "    pm.collectionVariables.set('simulationUsers', JSON.stringify(users, null, 2));",
              "    pm.collectionVariables.set('simulationSummary', JSON.stringify(summary, null, 2));",
              "",
              "    pm.test('simulation created the requested number of users', function () {",
              "        pm.expect(users.length).to.eql(userCount);",
              "    });",
              "",
              "    pm.test('simulation sent the requested number of transactions to the target account', function () {",
              "        pm.expect(sentTransactions.length).to.eql(transactionCount);",
              "    });",
              "",
              "    pm.test('target account history is paginated', function () {",
              "        pm.expect(page1.data.pagination.page).to.eql(1);",
              "        pm.expect(page1.data.pagination.limit).to.eql(historyPageLimit);",
              "        pm.expect(page1.data.pagination.total).to.be.at.least(transactionCount);",
              "        pm.expect(page1.data.pagination.totalPages).to.be.above(1);",
              "        pm.expect(page1.data.transactions.length).to.eql(historyPageLimit);",
              "        pm.expect(page2.data.transactions.length).to.be.above(0);",
              "    });",
              "",
              "    pm.test('page 1 and page 2 return different records', function () {",
              "        const page1Ids = page1.data.transactions.map((transaction) => transaction._id);",
              "        const page2Ids = page2.data.transactions.map((transaction) => transaction._id);",
              "        const overlap = page1Ids.filter((id) => page2Ids.includes(id));",
              "",
              "        pm.expect(overlap.length).to.eql(0);",
              "    });",
              "})().catch((error) => {",
              "    pm.collectionVariables.set('simulationSummary', error.message);",
              "    pm.test('simulation failed', function () {",
              "        throw error;",
              "    });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            ""
          ]
        },
        "description": "This request checks that the API is reachable. The Tests script performs the full load simulation using pm.sendRequest."
      },
      "response": []
    }
  ]
}
