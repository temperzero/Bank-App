{
  "info": {
    "_postman_id": "bb4a0d42-a6b7-4e5c-9876-5a08d77d1001",
    "name": "Bank API Basic",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "senderEmail",
      "value": ""
    },
    {
      "key": "recipientEmail",
      "value": ""
    },
    {
      "key": "senderUserId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Signup Sender",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var suffix = Date.now().toString().slice(-8);",
              "pm.collectionVariables.set('senderEmail', 'omer-basic-' + suffix + '@gmail.com');",
              "pm.collectionVariables.set('recipientEmail', 'friend-basic-' + suffix + '@gmail.com');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('sender signup created user', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('senderUserId', json.userId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{senderEmail}}\",\n  \"password\": \"0000\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:3000/auth/signup",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "auth",
            "signup"
          ]
        }
      },
      "response": []
    },
